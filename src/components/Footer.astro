---
import logoPin from '../assets/logo-pin.svg'
import { author } from '../sample'
---

<footer class="border-t-4 px-5 py-10 mt-30">
    <div class="max-w-3xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="font-bold">
        <a href="/" class="flex items-center gap-3 text-xl">
            <img src={logoPin.src} alt="logo" width="20" /> {author.nickname}
        </a>
      </div>
      <p class="text-sm">&copy; {new Date().getFullYear()} {author.name}. Todos los derechos reservados.</p>
    </div>
   </footer>
