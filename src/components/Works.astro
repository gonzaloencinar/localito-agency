---
import Bars from "./Bars.astro"
import { buy } from "../sample"

import svgUnderline from '../assets/underline.svg'

const portfolio = [
  {
    name: 'Restaurante La Brasería', desc: `+340% visibilidad en Google Maps en 4 meses`,
    cover: `https://images.pexels.com/photos/67468/pexels-photo-67468.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
  },
  {
    name: 'Clínica Dentaly', desc: `De página 3 a top 3 en búsquedas locales`,
    cover: `https://images.pexels.com/photos/3845810/pexels-photo-3845810.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
  },
  {
    name: 'Tienda Eco Verde', desc: `+280% en llamadas desde Google Business Profile`,
    cover: `https://images.pexels.com/photos/1005638/pexels-photo-1005638.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
  },
  {
    name: 'CrossFit Impulso', desc: `150 reseñas nuevas y 4.8 estrellas en 6 meses`,
    cover: `https://images.pexels.com/photos/1552242/pexels-photo-1552242.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
  },
]
---


<section class="py-25 space-y-10 px-5" id="casos">
    <div class="max-w-md mx-auto relative ">
      <h2 class="text-4xl font-medium text-center">Casos de Éxito</h2>
      <img src={svgUnderline.src} alt="arrow" width="140" class="absolute left-50 -bottom-1" />
    </div>

    <div class="max-w-3xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10">
      {portfolio.map(item => (
        <div class="flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.3)]">
          <div class="w-full h-[200px] overflow-hidden border-2">
           <img src={item.cover} alt={item.name} class="w-full h-full object-cover" />
          </div>
          <div class="space-y-1 pt-4">
            <div>
              <h3 class="text-xl font-medium">{item.name}</h3>
            </div>
            <p class="mr-20">{item.desc}</p>
          </div>
          <Bars />
        </div>
      ))}
    </div>
</section>
