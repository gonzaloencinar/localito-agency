---
import svgPinkStar from '../assets/pink-star.svg'

const sectors = [
  { icon: 'ri-restaurant-line', name: 'Restaurantes', result: '+300% reservas online' },
  { icon: 'ri-sparkling-line', name: 'Clínicas Estéticas', result: 'Top 3 en búsquedas locales' },
  { icon: 'ri-store-2-line', name: 'Tiendas', result: '+250% visitas desde Maps' },
  { icon: 'ri-boxing-line', name: 'Gimnasios', result: '2x nuevas altas al mes' },
  { icon: 'ri-scales-3-line', name: 'Abogados', result: '+180% consultas orgánicas' },
  { icon: 'ri-hotel-line', name: 'Hoteles', result: '+200% reservas directas' },
  { icon: 'ri-home-gear-line', name: 'Reformas', result: 'Agenda llena en 4 meses' },
  { icon: 'ri-tooth-line', name: 'Clínicas Dentales', result: '+260% llamadas desde Google' },
  { icon: 'ri-steering-line', name: 'Autoescuelas', result: '+190% solicitudes de matrícula' },
  { icon: 'ri-heart-pulse-line', name: 'Fisioterapeutas', result: 'Agenda completa en 3 meses' },
  { icon: 'ri-home-smile-line', name: 'Inmobiliarias', result: '+220% contactos desde Maps' },
  { icon: 'ri-bear-smile-line', name: 'Veterinarias', result: '+170% nuevos pacientes al mes' },
]
---

<section class="py-20 px-3 md:px-10 relative overflow-hidden" id="sectores">
  <img src={svgPinkStar.src} alt="svg" width="80" class="absolute -right-8 top-10" />

  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-medium">Sectores que posicionamos</h2>
      <p class="text-lg mt-3">Experiencia real en los negocios locales que más se benefician del SEO local</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {sectors.map(sector => (
        <div class="bg-white border-2 p-5 flex flex-col items-center text-center gap-2 transition-all duration-200 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.3)]">
          <i class={`${sector.icon} text-3xl`}></i>
          <h3 class="text-lg font-medium">{sector.name}</h3>
          <p class="text-xs text-gray-600">{sector.result}</p>
        </div>
      ))}
    </div>
  </div>
</section>
