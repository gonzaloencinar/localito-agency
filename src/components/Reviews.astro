---
import svgNew from '../assets/new.svg'

const testimonials = [
  {
    comment: `"Gracias a Localito, cualquiera que busca impresión 3D en nuestra zona nos encuentra primero. Las solicitudes de presupuesto se han disparado."`,
    author: {
      name: `Manuel de la Viña`,
      pos: `CEO, Prototipalo`,
      pic: `https://images.pexels.com/photos/614810/pexels-photo-614810.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
    },
    cls: `rotate-2 -translate-y-10`
   },
   {
    comment: `"En 3 meses pasamos de no aparecer en Google a ser el primer resultado en 'dentista cerca de mí'. Muy recomendable."`,
    author: {
      name: `Carlos Ruiz`,
      pos: `Director, Clínica Dentaly`,
      pic: `https://images.pexels.com/photos/3785079/pexels-photo-3785079.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
    },
    cls: `-rotate-2 -translate-x-10  z-5`
   },
   {
    comment: `"Antes entre semana el restaurante estaba medio vacío. Desde que trabajamos con Localito llenamos incluso los martes."`,
    author: {
      name: `Laura Fernández`,
      pos: `Propietaria, Trattoria La Nonna`,
      pic: `https://images.pexels.com/photos/2169429/pexels-photo-2169429.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
    },
    cls: `rotate-2 translate-x-5 z-5`
   },
   {
    comment: `"Profesionales, transparentes y con resultados reales. El mejor equipo de SEO local con el que hemos trabajado."`,
    author: {
      name: `Javier López`,
      pos: `Propietario, CrossFit Impulso`,
      pic: `https://images.pexels.com/photos/1756959/pexels-photo-1756959.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
    },
    cls: `-rotate-2 translate-y-10 md:translate-y-15`
   },
]
---


<section>
    <div class="max-w-4xl mx-auto pb-20 px-10 overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="flex relative">
          <h2 class="text-3xl">Lo que dicen nuestros clientes sobre nuestro trabajo</h2>
          <img src={svgNew.src} alt="arrow" width="40" class="absolute -right-3 md:-right-10 bottom-0" />
        </div>
      </div>


      <div class="grid grid-cols-1 md:grid-cols-2 py-30">
        {testimonials.map(item => (
          <div class={`flex flex-col gap-3 p-5 pr-15 bg-white border-2 shadow-[6px_6px_0px_rgba(0,0,0,0.3)] ${item.cls}`}>
            <p>{item.comment}</p>
            <div class="flex items-center gap-2">
              <div><div class="size-11 rounded-full border overflow-hidden">
                  <img src={item.author.pic} alt="" class="w-full h-full object-cover" />
              </div></div>
              <div>
                <h3 class="font-medium">{item.author.name}</h3>
                <p>{item.author.pos}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
   </section>
